      background:#253447; border:none; border-radius:8px;
      gridline-color:#2a3d55; color:#c8d6e5;
    }
    QTableWidget::item:selected { background:#4a9eff30; color:#ffffff; }
    QHeaderView::section { background:#1e2a3a; color:#8a9bb0; padding:8px; border:none; border-bottom:1px solid #2a3d55; }
    QPushButton#btnLogout {
