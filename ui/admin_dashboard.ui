      background: transparent; color: #8a9bb0;
      border: none; border-radius: 6px;
      text-align: left; padding: 10px 16px;
      font-size: 13px;
    }
    QPushButton.navBtn:hover  { background:#1e2a3a; color:#ffffff; }
    QPushButton.navBtn:checked{ background:#4a9eff20; color:#4a9eff; border-left:3px solid #4a9eff; }
