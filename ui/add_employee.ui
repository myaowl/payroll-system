  <property name="styleSheet">
   <string>
    QDialog { background:#1e2a3a; }
    QLabel  { color:#c8d6e5; font-size:13px; }
    QLabel#dlgTitle { color:#ffffff; font-size:17px; font-weight:bold; }
    QLineEdit, QComboBox, QDateEdit {
      background:#253447; border:1px solid #3a4f66;
      border-radius:6px; padding:7px 10px; color:#ffffff; font-size:13px;
    }
    QLineEdit:focus, QComboBox:focus, QDateEdit:focus { border-color:#4a9eff; }
    QComboBox::drop-down { border:none; }
    QComboBox QAbstractItemView { background:#253447; color:#ffffff; selection-background-color:#4a9eff; }
    QPushButton#btnSave {
      background:#4a9eff; color:#fff; border:none;
      border-radius:6px; font-size:14px; font-weight:bold; padding:10px;
    }
    QPushButton#btnSave:hover { background:#3a8ef0; }
    QPushButton#btnCancel {
      background:#2a3d55; color:#c8d6e5; border:none;
      border-radius:6px; font-size:13px; padding:10px;
    }
    QPushButton#btnCancel:hover { background:#3a4f66; }
   </string>
